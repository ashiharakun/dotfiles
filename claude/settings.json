{
  "language": "Japanese",
  "tui": "fullscreen",
  "preferredNotifChannel": "ghostty",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": ["docker"],
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "*.githubusercontent.com",
        "*.npmjs.org",
        "pypi.org"
      ]
    },
    "filesystem": {
      "denyRead": [
        "~/.ssh",
        "~/.gnupg"
      ]
    }
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "command -v afplay >/dev/null && afplay /System/Library/Sounds/Ping.aiff || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "command -v afplay >/dev/null && afplay /System/Library/Sounds/Glass.aiff || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  }
}
